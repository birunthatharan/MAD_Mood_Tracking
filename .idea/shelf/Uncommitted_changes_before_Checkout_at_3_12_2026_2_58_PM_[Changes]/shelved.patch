@@ -0,0 +1,109 @@
+package com.example.mad_project.Project;
+
+
+import android.database.Cursor;
+import android.os.Bundle;
+import android.widget.ArrayAdapter;
+import android.widget.Button;
+import android.widget.EditText;
+import android.widget.Spinner;
+import android.widget.Toast;
+
+import androidx.appcompat.app.AppCompatActivity;
+
+import com.example.mad_project.R;
+
+public class EditMoodActivity extends AppCompatActivity {
+
+    Spinner spMood;
+    EditText etNote;
+    Button btnUpdate, btnDelete;
+
+    DBHelper db;
+    SessionManager session;
+
+    long moodId;
+
+    String[] moods = {"Happy", "Neutral", "Sad", "Angry", "Excited", "Tired"};
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        setContentView(R.layout.activity_edit_mood);
+
+        spMood = findViewById(R.id.spMood);
+        etNote = findViewById(R.id.etNote);
+        btnUpdate = findViewById(R.id.btnUpdate);
+        btnDelete = findViewById(R.id.btnDelete);
+
+        db = new DBHelper(this);
+        session = new SessionManager(this);
+
+        spMood.setAdapter(new ArrayAdapter<>(
+                this,
+                android.R.layout.simple_spinner_dropdown_item,
+                moods
+        ));
+
+        // Get mood_id from HistoryActivity
+        moodId = getIntent().getLongExtra("mood_id", -1);
+
+        if (moodId == -1) {
+            Toast.makeText(this, "Invalid mood item", Toast.LENGTH_SHORT).show();
+            finish();
+            return;
+        }
+
+        loadOldData();
+
+        btnUpdate.setOnClickListener(v -> {
+            String newMood = spMood.getSelectedItem().toString();
+            String newNote = etNote.getText().toString().trim();
+
+            int rows = db.updateMood(moodId, session.getUserId(), newMood, newNote);
+
+            if (rows > 0) {
+                Toast.makeText(this, "Updated successfully", Toast.LENGTH_SHORT).show();
+                finish();
+            } else {
+                Toast.makeText(this, "Update failed", Toast.LENGTH_SHORT).show();
+            }
+        });
+
+        btnDelete.setOnClickListener(v -> {
+            int rows = db.deleteMood(moodId, session.getUserId());
+
+            if (rows > 0) {
+                Toast.makeText(this, "Deleted successfully", Toast.LENGTH_SHORT).show();
+                finish();
+            } else {
+                Toast.makeText(this, "Delete failed", Toast.LENGTH_SHORT).show();
+            }
+        });
+    }
+
+    private void loadOldData() {
+        long userId = session.getUserId();
+
+        Cursor c = db.getReadableDatabase().rawQuery(
+                "SELECT mood, note FROM moods WHERE id=? AND user_id=?",
+                new String[]{String.valueOf(moodId), String.valueOf(userId)}
+        );
+
+        if (c.moveToFirst()) {
+            String oldMood = c.getString(0);
+            String oldNote = c.getString(1);
+
+            etNote.setText(oldNote);
+
+            for (int i = 0; i < moods.length; i++) {
+                if (moods[i].equalsIgnoreCase(oldMood)) {
+                    spMood.setSelection(i);
+                    break;
+                }
+            }
+        }
+
+        c.close();
+    }
+}
