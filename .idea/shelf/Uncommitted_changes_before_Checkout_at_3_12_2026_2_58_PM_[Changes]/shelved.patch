+package com.example.mad_project.Project;
+import android.content.Intent;
+import android.database.Cursor;
+import android.os.Bundle;
+import android.widget.ArrayAdapter;
+import android.widget.Button;
+import android.widget.EditText;
+import android.widget.Spinner;
+import android.widget.Toast;
+
+import androidx.appcompat.app.AppCompatActivity;
+
+import com.example.mad_project.R;
+
+import java.text.SimpleDateFormat;
+import java.util.Date;
+import java.util.Locale;
+
+public class HomeActivity extends AppCompatActivity {
+
+    Spinner spMood;
+    EditText etNote;
+    Button btnSave, btnEditLastMood, btnHistory, btnLogout;
+
+    DBHelper db;
+    SessionManager session;
+
+    String[] moods = {"Happy", "Neutral", "Sad", "Angry", "Excited", "Tired"};
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        setContentView(R.layout.activity_home);
+
+        spMood = findViewById(R.id.spMood);
+        etNote = findViewById(R.id.etNote);
+        btnSave = findViewById(R.id.btnSave);
+        btnEditLastMood = findViewById(R.id.btnEditLastMood); // ✅ NEW
+        btnHistory = findViewById(R.id.btnHistory);
+        btnLogout = findViewById(R.id.btnLogout);
+
+        db = new DBHelper(this);
+        session = new SessionManager(this);
+
+        spMood.setAdapter(new ArrayAdapter<>(
+                this,
+                android.R.layout.simple_spinner_dropdown_item,
+                moods
+        ));
+
+        // Save Mood
+        btnSave.setOnClickListener(v -> {
+            long userId = session.getUserId();
+            String mood = spMood.getSelectedItem().toString();
+            String note = etNote.getText().toString().trim();
+
+
+            String date = new SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault())
+                    .format(new Date());
+
+            long result = db.addMood(userId, mood, note, date);
+
+            if (result > 0) {
+                Toast.makeText(this, "Mood Saved", Toast.LENGTH_SHORT).show();
+                etNote.setText("");
+            } else {
+                Toast.makeText(this, "Failed to save", Toast.LENGTH_SHORT).show();
+            }
+        });
+
+        // ✅ Edit Last Mood Button
+        btnEditLastMood.setOnClickListener(v -> {
+            long moodId = getLatestMoodId(session.getUserId());
+
+            if (moodId == -1) {
+                Toast.makeText(this, "No mood entries to edit", Toast.LENGTH_SHORT).show();
+                return;
+            }
+
+            Intent i = new Intent(this, EditMoodActivity.class);
+            i.putExtra("mood_id", moodId);
+            startActivity(i);
+        });
+
+        // History
+        btnHistory.setOnClickListener(v ->
+                startActivity(new Intent(this, HistoryActivity.class))
+        );
+
+        // Logout
+        btnLogout.setOnClickListener(v -> {
+            session.logout();
+            startActivity(new Intent(this, LoginActivity.class));
+            finish();
+        });
+    }
+
+    // ✅ Get latest mood entry ID of this user
+    private long getLatestMoodId(long userId) {
+        Cursor c = db.getReadableDatabase().rawQuery(
+                "SELECT id FROM moods WHERE user_id=? ORDER BY id DESC LIMIT 1",
+                new String[]{String.valueOf(userId)}
+        );
+
+        long id = -1;
+        if (c.moveToFirst()) id = c.getLong(0);
+        c.close();
+        return id;
+    }
+}
