@@ -0,0 +1,84 @@
+package com.example.mad_project.Project;
+
+import android.content.Intent;
+import android.database.Cursor;
+import android.os.Bundle;
+import android.widget.ArrayAdapter;
+import android.widget.ListView;
+
+import androidx.appcompat.app.AppCompatActivity;
+
+import com.example.mad_project.R;
+
+import java.util.ArrayList;
+
+public class HistoryActivity extends AppCompatActivity {
+
+    ListView listHistory;
+
+    DBHelper db;
+    SessionManager session;
+
+    ArrayList<String> moodList;
+    ArrayList<Long> moodIds;
+    ArrayAdapter<String> adapter;
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        setContentView(R.layout.activity_history);
+
+        listHistory = findViewById(R.id.listHistory);
+
+        db = new DBHelper(this);
+        session = new SessionManager(this);
+
+        moodList = new ArrayList<>();
+        moodIds = new ArrayList<>();
+
+        loadData();
+
+        listHistory.setOnItemClickListener((parent, view, position, id) -> {
+            Intent intent = new Intent(this, EditMoodActivity.class);
+            intent.putExtra("mood_id", moodIds.get(position));
+            startActivity(intent);
+        });
+    }
+
+    private void loadData() {
+        moodList.clear();
+        moodIds.clear();
+
+        long userId = session.getUserId();
+        Cursor cursor = db.getMoods(userId);
+
+        if (cursor != null && cursor.moveToFirst()) {
+            do {
+                long moodId = cursor.getLong(0);
+                String mood = cursor.getString(1);
+                String note = cursor.getString(2);
+                String date = cursor.getString(3);
+
+                moodIds.add(moodId);
+                moodList.add(date + "\n" + mood + " - " + note);
+
+            } while (cursor.moveToNext());
+
+            cursor.close();
+        }
+
+        adapter = new ArrayAdapter<>(
+                this,
+                android.R.layout.simple_list_item_1,
+                moodList
+        );
+
+        listHistory.setAdapter(adapter);
+    }
+
+    @Override
+    protected void onResume() {
+        super.onResume();
+        loadData();
+    }
+}
